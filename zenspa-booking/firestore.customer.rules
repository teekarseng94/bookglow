rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Customers signing up/logging in on the booking site
    // must be able to write only their own user document.
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Deny everything else by default (tight security).
    match /{document=**} {
      allow read, write: if false;
    }
  }
}

