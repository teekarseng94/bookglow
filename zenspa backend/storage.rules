rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Allow the app to manage staff photos
    match /staff_photos/{allPaths=**} {
      allow read: if true; // Allows the public booking site to see staff photos
      allow write: if request.auth != null; // Only logged-in admins can upload
    }

    // Fallback for other files
    match /{allPaths=**} {
      allow read, write: if request.auth != null;
    }
  }
}
